# ==================== SERVER ====================
NODE_ENV=development
PORT=5000
# Comma-separated list allowed for CORS (dev/prod)
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.com
# Set true when behind a trusted reverse proxy/load balancer
TRUST_PROXY=false

# ==================== DATABASE ====================
DATABASE_URL="postgresql://postgres:password@localhost:5432/grubgain_dev"

# ==================== JWT SECRETS ====================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_32_byte_hex_secret_here
JWT_REFRESH_SECRET=your_different_32_byte_hex_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookie policy for refresh token auth
# AUTH_COOKIE_SAMESITE: strict | lax | none
AUTH_COOKIE_SAMESITE=lax
# Set true when serving over HTTPS (recommended for production)
AUTH_COOKIE_SECURE=false

# ==================== ENCRYPTION KEYS ====================
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your_32_char_hex_key_here
ENCRYPTION_IV=your_16_char_hex_iv_here

# ==================== OPENAI API ====================
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ==================== META OAUTH ====================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_OAUTH_REDIRECT_URI=http://localhost:5000/api/v1/integrations/meta/callback
# Optional legacy/direct token-based integration values
META_USER_TOKEN=your_meta_user_token
META_APP_TOKEN=your_meta_app_token
# Optional seed helper token (used by prisma/seed.js)
META_ACCESS_TOKEN=your_meta_access_token
# Required only if using Meta webhook verification endpoint
META_WEBHOOK_VERIFY_TOKEN=your_meta_webhook_verify_token

# ==================== FILE STORAGE ====================
UPLOADS_DIR=public/uploads
MAX_FILE_SIZE=5242880

# ==================== GOOGLE SERVICES ====================
GOOGLE_SERVICES_API_KEY=your_google_api_key_here
# Optional Google OAuth flow values
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/v1/google/callback

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Enable authenticated test routes under /api/v1/content/test-* (dev/staging only)
ENABLE_TEST_ENDPOINTS=false

# ==================== LOGGING ====================
LOG_LEVEL=info
# Set true only when you need raw SQL query debug logs
PRISMA_LOG_QUERIES=false
# Request logging defaults to false in dev and true in production.
# Set explicitly when needed.
REQUEST_LOGGING=false
# Set true to log each scheduler run and pending checks
SCHEDULER_VERBOSE_LOGS=false
